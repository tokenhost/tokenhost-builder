{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tokenhost.com/schemas/tokenhost-ths.schema.json",
  "title": "Token Host Schema (THS)",
  "description": "Versioned schema document that defines an app (metadata + features) and collections (fields + rules) for deterministic generation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["thsVersion", "schemaVersion", "app", "collections"],
  "properties": {
    "thsVersion": {
      "type": "string",
      "minLength": 1,
      "description": "THS document format version (e.g. 2025-12)."
    },
    "schemaVersion": {
      "type": "string",
      "description": "App semantic version.",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "slug"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "slug": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "description": { "type": "string" },
        "brand": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primaryText": { "type": "string", "minLength": 1 },
            "accentText": { "type": "string", "minLength": 1 }
          }
        },
        "primaryCollection": { "type": "string", "minLength": 1 },
        "theme": {
          "type": "object",
          "description": "Theme preset selection and future theme options.",
          "additionalProperties": true,
          "properties": {
            "preset": {
              "type": "string",
              "enum": ["cyber-grid"]
            }
          }
        },
        "ui": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "homePage": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["generated", "custom"]
                }
              }
            },
            "extensions": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "directory": {
                  "type": "string",
                  "description": "Path to UI override files, resolved relative to the schema file."
                }
              }
            },
            "generated": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "feeds": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/generatedFeed" }
                },
                "tokenPages": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/generatedTokenPage" }
                },
                "homeSections": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/generatedHomeSection" }
                }
              }
            }
          }
        },
        "features": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "indexer": { "type": "boolean" },
            "delegation": { "type": "boolean" },
            "uploads": { "type": "boolean" },
            "onChainIndexing": { "type": "boolean" }
          }
        }
      }
    },
    "collections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/collection" }
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata (createdBy, createdAt, tags, etc).",
      "additionalProperties": true
    }
  },
  "$defs": {
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "fields",
        "createRules",
        "visibilityRules",
        "updateRules",
        "deleteRules",
        "indexes"
      ],
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Z][A-Za-z0-9]*$" },
        "plural": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        },
        "createRules": { "$ref": "#/$defs/createRules" },
        "visibilityRules": { "$ref": "#/$defs/visibilityRules" },
        "updateRules": { "$ref": "#/$defs/updateRules" },
        "deleteRules": { "$ref": "#/$defs/deleteRules" },
        "transferRules": { "$ref": "#/$defs/transferRules" },
        "indexes": { "$ref": "#/$defs/indexes" },
        "relations": {
          "type": "array",
          "items": { "$ref": "#/$defs/relation" }
        },
        "ui": {
          "type": "object",
          "description": "Per-collection UI overrides (implementation-defined).",
          "additionalProperties": true
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "uint256",
            "int256",
            "decimal",
            "bool",
            "address",
            "bytes32",
            "image",
            "reference",
            "externalReference"
          ]
        },
        "required": { "type": "boolean" },
        "decimals": { "type": "integer", "minimum": 0, "maximum": 18 },
        "default": {},
        "validation": {
          "type": "object",
          "additionalProperties": true
        },
        "ui": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "component": {
              "type": "string",
              "enum": ["default", "externalLink"]
            },
            "label": {
              "type": "string"
            },
            "target": {
              "type": "string",
              "enum": ["_blank", "_self"]
            }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "decimal" } } },
          "then": { "required": ["decimals"] }
        }
      ]
    },
    "access": {
      "type": "string",
      "enum": ["public", "owner", "allowlist", "role"]
    },
    "createRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "access"],
      "properties": {
        "required": { "type": "array", "items": { "type": "string" } },
        "auto": {
          "type": "object",
          "description": "Map of field->expression. Expressions are a limited safe set (validated semantically).",
          "additionalProperties": { "type": "string" }
        },
        "payment": { "$ref": "#/$defs/payment" },
        "access": { "$ref": "#/$defs/access" }
      }
    },
    "payment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset", "amountWei"],
      "properties": {
        "asset": { "type": "string", "enum": ["native"] },
        "amountWei": { "type": "string", "pattern": "^[0-9]+$" }
      }
    },
    "visibilityRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gets", "access"],
      "properties": {
        "gets": { "type": "array", "items": { "type": "string" } },
        "access": { "$ref": "#/$defs/access" }
      }
    },
    "updateRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mutable", "access"],
      "properties": {
        "mutable": { "type": "array", "items": { "type": "string" } },
        "access": { "$ref": "#/$defs/access" },
        "optimisticConcurrency": { "type": "boolean" }
      }
    },
    "deleteRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["softDelete", "access"],
      "properties": {
        "softDelete": { "type": "boolean" },
        "access": { "$ref": "#/$defs/access" }
      }
    },
    "transferRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["access"],
      "properties": {
        "access": { "$ref": "#/$defs/access" }
      }
    },
    "indexes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unique", "index"],
      "properties": {
        "unique": {
          "type": "array",
          "items": { "$ref": "#/$defs/uniqueIndex" }
        },
        "index": {
          "type": "array",
          "description": "Equality/query indexes (implementation-defined).",
          "items": { "$ref": "#/$defs/queryIndex" }
        }
      }
    },
    "uniqueIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field"],
      "properties": {
        "field": { "type": "string" },
        "scope": { "type": "string", "enum": ["active", "allTime"] }
      }
    },
    "queryIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field"],
      "properties": {
        "field": { "type": "string" },
        "mode": { "type": "string", "enum": ["equality", "tokenized"] },
        "tokenizer": { "type": "string", "enum": ["hashtag"] }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": { "const": "tokenized" }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["tokenizer"]
          }
        },
        {
          "if": {
            "required": ["tokenizer"]
          },
          "then": {
            "properties": {
              "mode": { "const": "tokenized" }
            }
          }
        }
      ]
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "to"],
      "properties": {
        "field": { "type": "string" },
        "to": { "type": "string" },
        "enforce": { "type": "boolean" },
        "mustOwn": { "type": "boolean" },
        "reverseIndex": { "type": "boolean" }
      }
    },
    "generatedAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "href"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "href": { "type": "string", "minLength": 1 },
        "variant": { "type": "string", "enum": ["default", "primary"] }
      }
    },
    "generatedFeedCard": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "referenceField": { "type": "string" },
        "textField": { "type": "string" },
        "mediaField": { "type": "string" }
      }
    },
    "generatedFeed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "collection"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9_-]*$" },
        "collection": { "type": "string" },
        "limit": { "type": "integer", "minimum": 1, "maximum": 100 },
        "card": { "$ref": "#/$defs/generatedFeedCard" }
      }
    },
    "generatedTokenPage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "collection", "field", "tokenizer"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9_-]*$" },
        "collection": { "type": "string" },
        "field": { "type": "string" },
        "tokenizer": { "type": "string", "enum": ["hashtag"] },
        "feed": { "type": "string" },
        "limit": { "type": "integer", "minimum": 1, "maximum": 100 },
        "title": { "type": "string" },
        "emptyTitle": { "type": "string" },
        "emptyBody": { "type": "string" }
      }
    },
    "generatedHeroSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title"],
      "properties": {
        "type": { "const": "hero" },
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "accent": { "type": "string" },
        "description": { "type": "string" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "$ref": "#/$defs/generatedAction" } }
      }
    },
    "generatedFeedSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "feed", "title"],
      "properties": {
        "type": { "const": "feed" },
        "feed": { "type": "string" },
        "title": { "type": "string" },
        "emptyTitle": { "type": "string" },
        "emptyBody": { "type": "string" }
      }
    },
    "generatedTokenListSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tokenPage", "title"],
      "properties": {
        "type": { "const": "tokenList" },
        "tokenPage": { "type": "string" },
        "title": { "type": "string" },
        "emptyBody": { "type": "string" }
      }
    },
    "generatedHomeSection": {
      "oneOf": [
        { "$ref": "#/$defs/generatedHeroSection" },
        { "$ref": "#/$defs/generatedFeedSection" },
        { "$ref": "#/$defs/generatedTokenListSection" }
      ]
    }
  }
}
