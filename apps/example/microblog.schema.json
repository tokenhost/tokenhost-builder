{
  "thsVersion": "2025-12",
  "schemaVersion": "0.1.0",
  "app": {
    "name": "Microblog",
    "slug": "microblog",
    "theme": {
      "preset": "cyber-grid"
    },
    "features": {
      "uploads": true,
      "onChainIndexing": true
    },
    "ui": {
      "homePage": { "mode": "custom" },
      "extensions": { "directory": "microblog-ui" }
    }
  },
  "collections": [
    {
      "name": "Profile",
      "fields": [
        { "name": "handle", "type": "string", "required": true },
        { "name": "displayName", "type": "string" },
        { "name": "bio", "type": "string" },
        { "name": "avatar", "type": "image" }
      ],
      "createRules": { "required": ["handle"], "access": "public" },
      "visibilityRules": { "gets": ["handle", "displayName", "bio", "avatar"], "access": "public" },
      "updateRules": { "mutable": ["handle", "displayName", "bio", "avatar"], "access": "owner" },
      "deleteRules": { "softDelete": true, "access": "owner" },
      "transferRules": { "access": "owner" },
      "indexes": {
        "unique": [{ "field": "handle", "scope": "allTime" }],
        "index": []
      }
    },
    {
      "name": "Post",
      "fields": [
        { "name": "authorProfile", "type": "reference", "required": true },
        { "name": "body", "type": "string", "required": true },
        { "name": "image", "type": "image" }
      ],
      "createRules": { "required": ["authorProfile", "body"], "access": "public" },
      "visibilityRules": { "gets": ["authorProfile", "body", "image"], "access": "public" },
      "updateRules": { "mutable": ["body", "image"], "access": "owner" },
      "deleteRules": { "softDelete": true, "access": "owner" },
      "transferRules": { "access": "owner" },
      "indexes": {
        "unique": [],
        "index": [
          { "field": "authorProfile" },
          { "field": "body", "mode": "tokenized", "tokenizer": "hashtag" }
        ]
      },
      "relations": [
        { "field": "authorProfile", "to": "Profile", "enforce": true, "reverseIndex": true }
      ]
    }
  ]
}
